# Copy this file to .env and fill in your values
# NEVER commit .env

# DB_HOST=localhost  ← dev local (uvicorn direct)
# DB_HOST=db        ← prod Docker (injecté automatiquement par docker-compose, ne pas changer)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=datagest
DB_USER=postgres
DB_PASSWORD=changeme

DEBUG=false

# Add your Raspberry Pi IP if you want to allow direct backend access (optional, Nginx handles it)
# CORS_ORIGINS=["http://192.168.1.x"]
